# Browser-safe Supabase settings (Netlify environment variables)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Same Supabase values for Netlify Functions (server-side token verification)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only Claude settings. Never prefix these with VITE_.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
CLAUDE_HAIKU_MODEL=YOUR_CLAUDE_HAIKU_MODEL_ID
CLAUDE_SONNET_MODEL=YOUR_CLAUDE_SONNET_MODEL_ID
# Optional migration fallback. Used if either model-specific value is absent.
CLAUDE_MODEL=YOUR_FALLBACK_CLAUDE_MODEL_ID

# Server-only speech transcription settings for Rita audio attachments.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
