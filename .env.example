# Supabase 연동 값. Netlify에는 이미 등록되어 있고, "로컬에서 테스트"하려면
# 이 파일을 복사해 .env 로 만들고 아래 두 값을 채우세요(.env 는 git에 올라가지 않습니다).
# 두 값은 Supabase 대시보드 → Project Settings → API 에서 확인합니다.
#  - VITE_SUPABASE_URL: Project URL
#  - VITE_SUPABASE_ANON_KEY: anon public key (프런트에 노출돼도 안전한 공개 키입니다)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase env가 비어 있으면 자동으로 로그인 없이 mock 세션 모드로 동작합니다
# (로컬 개발 편의). env가 채워지면 로그인 후 Supabase 데이터로 동작합니다.
VITE_USE_MOCK=true
